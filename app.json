{
  "expo": {
    "name": "PulseSpend",
    "slug": "pulsespend",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.pulsespend.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#07111F"
      },
      "permissions": [
        "READ_SMS",
        "READ_CONTACTS"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
